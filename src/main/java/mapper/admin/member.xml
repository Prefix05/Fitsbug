<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="mapper.admin.member">
	<select id="selectAllGym" parameterType="String" resultType="member">
		select g.name, u.tel, u.created_at, count() from gym g 
		left join user u on(g.user_id=u.id)
		left join client c on(g.id=c.gym_id)
		
	</select>
	<select id="selectAllTrainer" parameterType="String" resultType="member">
		select * from trainer
	</select>
	<select id="selectAllClient" parameterType="String" resultType="member">
		select * from client
	</select>

</mapper>	